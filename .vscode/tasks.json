{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend Server",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "NODE_ENV": "production"
        }
      },
      "problemMatcher": [],
      "detail": "Start the backend server in production mode"
    },
    {
      "label": "Start Backend (Development)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "^(.*)\\((\\d+)\\)\\s+:\\s+(.*)$",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": ".*"
          }
        }
      ],
      "detail": "Start the backend server in development mode with auto-restart"
    },
    {
      "label": "Test Database Connection",
      "type": "shell",
      "command": "node",
      "args": ["-e", "require('./config/db').testConnection().then(result => process.exit(result ? 0 : 1))"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "detail": "Test the PostgreSQL database connection"
    },
    {
      "label": "Install Backend Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "detail": "Install all backend dependencies from package.json"
    },
    {
      "label": "Check Backend Syntax",
      "type": "shell",
      "command": "node",
      "args": ["-c", "server.js"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "detail": "Check syntax of the main server.js file"
    },
    {
      "label": "Kill Backend Process",
      "type": "shell",
      "command": "pkill",
      "args": ["-f", "node.*server.js"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Kill any running backend server processes"
    },
    {
      "label": "View Backend Logs",
      "type": "shell",
      "command": "tail",
      "args": ["-f", "/dev/null"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Keep terminal open for viewing logs (use with other tasks)"
    }
  ]
}